# Portal — on-premises
# Copie para .env, preencha os valores e execute:
#   chmod 600 .env
#   docker compose up -d

# Imagem Docker
DOCKER_USERNAME=suportess
IMAGE_TAG=latest

# Servidor
SERVER_PORT=8080
DEFAULT_TIMEOUT=60
STATUS=UP

# Banco de dados local (BoltDB)
DATABASE=portal.db
DATABASE_PATH=db
DATABASE_TIMEOUT=10

# Chave Bearer para autenticar chamadas recebidas pelo portal
GATEWAY_API_KEY=

# Token de autenticação da conta ngrok (Dashboard → Authtokens)
NGROK_AUTHTOKEN=

# Domínio reservado gerado pelo suportes (ex: abc123.ngrok-free.app)
NGROK_DOMAIN=
