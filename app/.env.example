# Servidor HTTP
SERVER_PORT=8080
DEFAULT_TIMEOUT=60

# Status da aplicação (UP | DOWN | MAINTENANCE)
STATUS=UP

# Chave de autenticação da API (Bearer token)
AGENTE_API_KEY=agente-default-api-key-2025

# Banco de dados local BoltDB (armazenamento de configurações)
DATABASE=agente.db
DATABASE_PATH=db
DATABASE_TIMEOUT=10

# Tracing distribuído (Jaeger / OpenTelemetry)
JAEGER_ENABLED=false
JAEGER_SERVICE_NAME=agente
JAEGER_SERVICE_VERSION=1.0.0
JAEGER_ENVIRONMENT=development
JAEGER_ENDPOINT=http://localhost:4318

# ─── ngrok (túnel público — on-premises) ─────────────────────────────────────
# Token de autenticação da sua conta ngrok (obrigatório)
NGROK_AUTHTOKEN=

# Domínio reservado salvo em conf_empresa.ds_host_portal (ex: abc123.ngrok-free.app)
NGROK_DOMAIN=
